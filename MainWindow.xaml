<Window x:Class="SherioAPP.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        Width="800"
        Height="500">

    <Window.Resources>
        <Style TargetType="ScrollBar">
            <Setter Property="Visibility" Value="Collapsed"/>
        </Style>
    </Window.Resources>

    <Border Background="White">

        <Grid>

            <!-- כפתור יציאה -->
            <Button Width="32"
        Height="32"
        HorizontalAlignment="Left"
        VerticalAlignment="Top"
        Margin="10"
        Panel.ZIndex="999"
        Cursor="Hand"
        Click="Exit_Click"
        Background="Transparent"
        BorderThickness="0"
        ToolTip="יציאה מהאפליקציה">

                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                    Width="32"
                    Height="32"
                    Background="Transparent"
                    CornerRadius="16">
                            <materialDesign:PackIcon
                    x:Name="Icon"
                    Kind="Close"
                    Width="18"
                    Height="18"
                    Foreground="#6B7280"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <!-- Hover -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root"
                            Property="Background"
                            Value="#FEE2E2"/>
                                <Setter TargetName="Icon"
                            Property="Foreground"
                            Value="#DC2626"/>
                            </Trigger>

                            <!-- Click -->
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root"
                            Property="Background"
                            Value="#FECACA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <!-- כאן נטענים העמודים -->
            <Frame x:Name="MainFrame"
                   NavigationUIVisibility="Hidden"/>

            <!-- כפתור חזרה -->
            <Button Width="32"
        Height="32"
        HorizontalAlignment="Left"
        VerticalAlignment="Top"
        Margin="52,10,0,0"
        Panel.ZIndex="999"
        Cursor="Hand"
                    IsEnabled="{Binding ElementName=MainFrame, Path=CanGoBack}"
        Click="Back_Click"
        Background="Transparent"
        BorderThickness="0"
        ToolTip="חזרה למסך הקודם">

                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                    Width="32"
                    Height="32"
                    Background="Transparent"
                    CornerRadius="16">

                            <materialDesign:PackIcon
                    x:Name="Icon"
                    Kind="ArrowRight"
                    Width="18"
                    Height="18"
                    Foreground="#6B7280"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"/>
                        </Border>

                        <ControlTemplate.Triggers>

                            <!-- Hover -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root"
                            Property="Background"
                            Value="#E0E7FF"/>
                                <Setter TargetName="Icon"
                            Property="Foreground"
                            Value="#2563EB"/>
                            </Trigger>

                            <!-- Click -->
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root"
                            Property="Background"
                            Value="#C7D2FE"/>
                            </Trigger>

                            <!-- Disable -->
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Icon"
                            Property="Foreground"
                            Value="#D1D5DB"/>
                            </Trigger>

                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

        </Grid>

    </Border>
</Window>
