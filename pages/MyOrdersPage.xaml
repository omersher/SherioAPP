<Page x:Class="SherioAPP.pages.MyOrdersPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      xmlns:model="clr-namespace:Model;assembly=Model" 
      Title="ההזמנות שלי"
      FlowDirection="RightToLeft"
      Height="500" Width="800">

    <Grid Background="#F3F4F6">
        <Grid.RowDefinitions>
            <RowDefinition Height="65"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <materialDesign:Card Grid.Row="0" Background="White" Padding="10" UniformCornerRadius="0">
            <Grid>
                <Button HorizontalAlignment="Left"
                        Style="{StaticResource MaterialDesignFlatButton}"
                        Click="Back_Click"
                        Foreground="#3B82F6">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="ArrowRight" VerticalAlignment="Center"/>
                        <TextBlock Text="חזרה" Margin="8,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <TextBlock Text="ההזמנות שלי"
                           FontSize="20" FontWeight="Bold"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Grid>
        </materialDesign:Card>

        <ScrollViewer Grid.Row="1">
            <ItemsControl x:Name="OrdersList" Margin="20">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <materialDesign:Card Margin="0,0,0,18" Padding="22" UniformCornerRadius="14">

                            <StackPanel>

                                <!-- Header -->
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Status Badge -->
                                    <Border Padding="8,4"
                        CornerRadius="12"
                        Background="#E5E7EB">
                                        <TextBlock Text="{Binding Status}"
                               FontWeight="Bold"
                               FontSize="13"
                               Foreground="#111827"/>
                                    </Border>

                                    <!-- Room -->
                                    <TextBlock Grid.Column="1"
                           Text="{Binding RoomID, StringFormat=חדר מספר {0}}"
                           HorizontalAlignment="Left"
                           FontWeight="SemiBold"
                           Foreground="#374151"/>
                                </Grid>

                                <Separator Margin="0,5,0,15" Background="#EEE"/>

                                <!-- Dates -->
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="צ'ק-אין"
                               FontSize="12"
                               Foreground="Gray"/>
                                        <TextBlock Text="{Binding StartDate, StringFormat={}{0:dd/MM/yyyy}}"
                               FontSize="15"
                               FontWeight="Medium"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="צ'ק-אאוט"
                               FontSize="12"
                               Foreground="Gray"/>
                                        <TextBlock Text="{Binding EndDate, StringFormat={}{0:dd/MM/yyyy}}"
                               FontSize="15"
                               FontWeight="Medium"/>
                                    </StackPanel>
                                </Grid>

                                <!-- Cancel Button -->
                                <Button Content="בטל הזמנה"
                    Margin="0,10,0,0"
                    Height="38"
                    Background="#EF4444"
                    Foreground="White"
                    Click="CancelBooking_Click"
                    Tag="{Binding}">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>

                                                <!-- Hide if already cancelled -->
                                                <DataTrigger Binding="{Binding Status}" Value="Cancelled">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>

                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>

                            </StackPanel>
                        </materialDesign:Card>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Page>