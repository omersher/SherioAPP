<Page x:Class="SherioAPP.pages.HotelDetailsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      Title="HotelDetails"
      Height="Auto" Width="800"
      FlowDirection="RightToLeft">

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Page.Resources>

    <materialDesign:DialogHost Identifier="RootDialog" x:Name="GalleryDialog">
        <materialDesign:DialogHost.DialogContent>
            <Border Padding="24" Background="White" CornerRadius="16" Width="650" MaxHeight="550">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="גלריית תמונות" FontSize="22" FontWeight="ExtraBold" Margin="0,0,0,15" Foreground="#1E293B"/>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="GalleryItemsControl">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel HorizontalAlignment="Center" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="8" CornerRadius="10" ClipToBounds="True" Background="#F1F5F9" Width="180" Height="130">
                                        <Image Source="{Binding ImageLink}" Stretch="UniformToFill" RenderOptions.BitmapScalingMode="HighQuality"/>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <Button Grid.Row="2" Content="סגור" IsCancel="True"
                            Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}"
                            Margin="0,20,0,0" Style="{StaticResource MaterialDesignFlatButton}" Foreground="#2563EB" FontWeight="Bold"/>
                </Grid>
            </Border>
        </materialDesign:DialogHost.DialogContent>

        <Grid Background="White">
            <ScrollViewer VerticalScrollBarVisibility="Hidden">
                <StackPanel Margin="0,0,0,40">

                    <Grid Height="380" Margin="15">
                        <Border CornerRadius="20" ClipToBounds="True">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="1*"/>
                                </Grid.ColumnDefinitions>

                                <Image x:Name="MainImage" Grid.Column="0" Stretch="UniformToFill" Margin="0,0,4,0"/>

                                <Grid Grid.Column="1">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <Image x:Name="SideImage1" Grid.Row="0" Stretch="UniformToFill" Margin="0,0,0,2"/>
                                    <Image x:Name="SideImage2" Grid.Row="1" Stretch="UniformToFill" Margin="0,2,0,0"/>
                                </Grid>

                                <Button VerticalAlignment="Bottom" HorizontalAlignment="Left" Margin="20" 
                                        Background="#CCFFFFFF" BorderThickness="0" Padding="15,8" Height="Auto" Click="OpenGallery_Click"
                                        materialDesign:ButtonAssist.CornerRadius="10" Cursor="Hand">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="ImageMultiple" Foreground="#1E293B" Width="20" Height="20"/>
                                        <TextBlock x:Name="GalleryText" Text="כל התמונות" Foreground="#1E293B" FontSize="14" FontWeight="Bold" Margin="8,0,0,0"/>
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </Border>
                    </Grid>

                    <StackPanel Margin="25,10,25,25">
                        <TextBlock Text="{Binding Name}" FontSize="34" FontWeight="ExtraBold" Foreground="#1E293B"/>
                        <StackPanel Orientation="Horizontal" Margin="0,8">
                            <materialDesign:PackIcon Kind="MapMarker" Foreground="#2563EB" VerticalAlignment="Center" Width="18" Height="18"/>
                            <TextBlock Text="{Binding City.Name}" Foreground="#64748B" FontSize="16" Margin="5,0"/>
                            <TextBlock Text=" • מיקום מצוין" Foreground="#2563EB" FontWeight="Bold" Margin="10,0"/>
                        </StackPanel>
                    </StackPanel>

                    <Border Background="White" Margin="15,0,15,0" Padding="15">
                        <StackPanel>
                            <TextBlock Text="זמינות חדרים" FontSize="22" FontWeight="ExtraBold" Margin="10,0,0,20" Foreground="#1E293B"/>

                            <DataGrid x:Name="RoomsGrid" 
                                      AutoGenerateColumns="False" 
                                      IsReadOnly="True" 
                                      CanUserAddRows="False" 
                                      GridLinesVisibility="Horizontal" 
                                      HeadersVisibility="Column"
                                      RowHeight="115" 
                                      Background="Transparent" 
                                      BorderThickness="0"
                                      ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                      PreviewMouseWheel="RoomsGrid_PreviewMouseWheel">
                                <DataGrid.Columns>

                                    <DataGridTemplateColumn Header="סוג חדר ומפרט" Width="2.5*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel VerticalAlignment="Center" Margin="15,0">
                                                    <TextBlock Text="{Binding RoomName}" FontWeight="ExtraBold" FontSize="18" Foreground="#1E293B"/>

                                                    <WrapPanel Margin="0,10,0,0">
                                                        <StackPanel Orientation="Horizontal" Margin="0,0,15,5" 
                                                                    Visibility="{Binding HasBalcony, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                            <materialDesign:PackIcon Kind="Balcony" Foreground="#10B981" Width="18" Height="18"/>
                                                            <TextBlock Text="מרפסת" FontSize="12" Foreground="#10B981" Margin="5,0,0,0" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                                        </StackPanel>

                                                        <StackPanel Orientation="Horizontal" Margin="0,0,15,5"
                                                                    Visibility="{Binding HasParking, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                            <materialDesign:PackIcon Kind="Parking" Foreground="#2563EB" Width="18" Height="18"/>
                                                            <TextBlock Text="חניה" FontSize="12" Foreground="#2563EB" Margin="5,0,0,0" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                                        </StackPanel>

                                                        <StackPanel Orientation="Horizontal" Margin="0,0,15,5"
                                                                    Visibility="{Binding HasKitchen, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                            <materialDesign:PackIcon Kind="Kitchen" Foreground="#F59E0B" Width="18" Height="18"/>
                                                            <TextBlock Text="מטבחון" FontSize="12" Foreground="#F59E0B" Margin="5,0,0,0" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                                        </StackPanel>

                                                        <StackPanel Orientation="Horizontal" Margin="0,0,15,5"
                                                                    Visibility="{Binding HasLivingR, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                            <materialDesign:PackIcon Kind="Sofa" Foreground="#8B5CF6" Width="18" Height="18"/>
                                                            <TextBlock Text="סלון" FontSize="12" Foreground="#8B5CF6" Margin="5,0,0,0" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                                        </StackPanel>
                                                    </WrapPanel>
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                    <DataGridTemplateColumn Header="מחיר ללילה" Width="1*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                                    <TextBlock Text="{Binding AdultRate, StringFormat='₪{0:N0}'}" 
                                                               FontWeight="ExtraBold" Foreground="#2563EB" FontSize="24"/>
                                                    <TextBlock Text="מחיר סופי" FontSize="11" Foreground="#94A3B8" HorizontalAlignment="Center"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                    <DataGridTemplateColumn Width="1.5*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button Content="הזמן עכשיו"
                                                         Style="{StaticResource MaterialDesignRaisedButton}"
                                                         Background="#2563EB"
                                                         Foreground="White"
                                                         BorderThickness="0"
                                                         Height="45"
                                                         Width="150"
                                                         materialDesign:ButtonAssist.CornerRadius="12"
                                                         FontSize="15"
                                                         FontWeight="Bold"
                                                         Cursor="Hand"
                                                         Click="OrderRoom_Click"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Border>
                    <Rectangle Height="40" Fill="Transparent"/>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </materialDesign:DialogHost>
</Page>