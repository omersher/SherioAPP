<Page x:Class="SherioAPP.pages.HotelDetailsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      Title="HotelDetails"
      Height="500" Width="800"
      FlowDirection="RightToLeft">

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Page.Resources>

    <Grid Background="#F3F4F6">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="0,0,0,20">

                <Grid Height="220" Margin="15,15,15,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" CornerRadius="12,0,0,12" ClipToBounds="True" Margin="0,0,4,0">
                        <Image Source="{Binding HotelImageLink}" Stretch="UniformToFill"/>
                    </Border>

                    <Grid Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" CornerRadius="0,12,0,0" ClipToBounds="True" Margin="0,0,0,2">
                            <Image Source="{Binding HotelImageLink}" Stretch="UniformToFill"/>
                        </Border>
                        <Border Grid.Row="1" CornerRadius="0,0,12,0" ClipToBounds="True" Margin="0,2,0,0">
                            <Grid>
                                <Image Source="{Binding HotelImageLink}" Stretch="UniformToFill"/>
                                <Border Background="#80000000">
                                    <TextBlock Text="+ 12 תמונות" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold"/>
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>

                <StackPanel Margin="20,5,20,15">
                    <TextBlock Text="{Binding Name}" FontSize="28" FontWeight="ExtraBold" Foreground="#1E293B"/>
                    <StackPanel Orientation="Horizontal" Margin="0,5">
                        <materialDesign:PackIcon Kind="MapMarker" Foreground="#2563EB" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding City.Name}" Foreground="#64748B" FontSize="14" Margin="5,0"/>
                        <TextBlock Text=" • מיקום מצוין" Foreground="#2563EB" FontWeight="SemiBold" Margin="10,0"/>
                    </StackPanel>
                </StackPanel>

                <Border Background="White" CornerRadius="12" Margin="15,0,15,0" Padding="10">
                    <StackPanel>
                        <TextBlock Text="זמינות חדרים" FontSize="18" FontWeight="Bold" Margin="10,10,10,15"/>

                        <DataGrid x:Name="RoomsGrid" 
                                  AutoGenerateColumns="False" 
                                  IsReadOnly="True" 
                                  CanUserAddRows="False"
                                  GridLinesVisibility="Horizontal"
                                  HorizontalGridLinesBrush="#F1F5F9"
                                  RowHeight="70"
                                  Background="Transparent"
                                  BorderThickness="0">

                            <DataGrid.Columns>
                                <DataGridTextColumn Header="סוג חדר" Binding="{Binding RoomName}" Width="150">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FontWeight" Value="Bold"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="Margin" Value="10,0"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <DataGridTemplateColumn Header="מפרט" Width="120">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Bedrooms, StringFormat='{}{0} חדרי שינה'}" FontSize="12" Foreground="#475569"/>
                                                <TextBlock Text="{Binding Bathrooms, StringFormat='{}{0} מקלחות'}" FontSize="12" Foreground="#475569"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTemplateColumn Header="מה בחדר?" Width="*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <WrapPanel VerticalAlignment="Center">
                                                <Border Background="#E1F5FE" CornerRadius="4" Padding="5,2" Margin="2"
                                                        Visibility="{Binding HasKitchen, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                    <TextBlock Text="מטבח" Foreground="#0288D1" FontSize="11" FontWeight="Bold"/>
                                                </Border>
                                                <Border Background="#E8F5E9" CornerRadius="4" Padding="5,2" Margin="2"
                                                        Visibility="{Binding HasParking, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                    <TextBlock Text="חניה" Foreground="#2E7D32" FontSize="11" FontWeight="Bold"/>
                                                </Border>
                                                <Border Background="#FFF1F1" CornerRadius="4" Padding="5,2" Margin="2"
                                                        Visibility="{Binding HasBalcony, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                    <TextBlock Text="מרפסת" Foreground="#D32F2F" FontSize="11" FontWeight="Bold"/>
                                                </Border>
                                                <Border Background="#F3E5F5" CornerRadius="4" Padding="5,2" Margin="2"
                                                        Visibility="{Binding HasLivingR, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                    <TextBlock Text="סלון" Foreground="#7B1FA2" FontSize="11" FontWeight="Bold"/>
                                                </Border>
                                            </WrapPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTemplateColumn Header="מחיר" Width="100">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                                <TextBlock Text="{Binding AdultRate, StringFormat='₪{0:N0}'}" FontWeight="ExtraBold" Foreground="#2563EB" FontSize="16"/>
                                                <TextBlock Text="ללילה" FontSize="10" Foreground="Gray" HorizontalAlignment="Center"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTemplateColumn Width="90">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="הזמן" Background="#2563EB" Foreground="White" BorderThickness="0"
                                                    Height="32" materialDesign:ButtonAssist.CornerRadius="6"
                                                    FontSize="12" FontWeight="Bold"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>