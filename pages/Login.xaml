<Page x:Class="SherioAPP.pages.Login"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      FlowDirection="RightToLeft"
      FontFamily="Segoe UI"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:SherioAPP.pages"
      mc:Ignorable="d" 
      d:DesignHeight="500" d:DesignWidth="800"
      Title="Login">

    <Grid Width="800"
          Height="500"
          Background="Transparent" 
          HorizontalAlignment="Center"
          VerticalAlignment="Center">

        <Border 
                Background="White"
                ClipToBounds="True">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.1*" />
                    <ColumnDefinition Width="1*" />
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0">
                    <Border Background="#66000000"/>
                    <Grid.Background>
                        <ImageBrush ImageSource="/images/hotelLogin.jpg"
                                    Stretch="UniformToFill"/>
                    </Grid.Background>
                </Grid>

                <StackPanel Grid.Column="1"
                            Margin="35"
                            VerticalAlignment="Center">

                    <TextBlock Text="ברוכים הבאים"
                               FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="#111827"
                               Margin="0 0 0 6"/>

                    <TextBlock Text="בבקשה הכנסו את הפרטים שלכם"
                               FontSize="13"
                               Foreground="#6B7280"
                               Margin="0 0 0 22"/>

                    <TextBlock Text="אימייל"
                               FontSize="12"
                               Foreground="#374151"
                               Margin="0 0 0 4"/>

                    <TextBox x:Name="EmailBox"
                             Height="36"
                             Padding="10"
                             FontSize="13"
                             Margin="0 0 0 14"/>

                    <TextBlock Text="סיסמה"
                               FontSize="12"
                               Foreground="#374151"
                               Margin="0 0 0 10"/>

                    <PasswordBox x:Name="PasswordBoxInput"
                                 Height="36"
                                 Padding="10"
                                 FontSize="13"/>

                    <!-- ✅ השם תואם ל-C# -->
                    <TextBlock x:Name="PasswordErrorText"
                               Foreground="#DC2626"
                               FontSize="11"
                               Height="16"
                               Margin="2 6 0 0"
                               Visibility="Collapsed"/>

                    <Button Content="התחברות"
                            Height="38"
                            Background="#111827"
                            Foreground="White"
                            BorderThickness="0"
                            FontSize="14"
                            Margin="0 22 0 14"
                            Cursor="Hand"
                            Click="Login_Click"/>

                    <StackPanel Orientation="Horizontal"
            HorizontalAlignment="Center"
            Margin="0,10,0,0">

                        <TextBlock Text="אין לך משתמש?"
               FontSize="12"
               Foreground="#6B7280"
               VerticalAlignment="Center"
               Margin="0,0,8,0"/>

                        <Button Content="הרשמה"
            FontSize="12"
            Foreground="#2563EB"
            Background="Transparent"
            BorderThickness="0"
            Padding="0"
            Cursor="Hand"
            FocusVisualStyle="{x:Null}"
            Click="Register_Click"
            VerticalAlignment="Center"/>

                        <TextBlock Text="|" 
               Foreground="#E5E7EB" 
               Margin="10,0" 
               VerticalAlignment="Center"/>

                        <Button Content="מילוי אוטומטי" 
            FontSize="12"
            Foreground="#2563EB"
            Background="Transparent"
            BorderThickness="0"
            Padding="0"
            Cursor="Hand"
            FocusVisualStyle="{x:Null}"
            Click="ForgotPassword_Click"
            VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Page>
