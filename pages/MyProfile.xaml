<Page x:Class="SherioAPP.pages.MyProfile"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      xmlns:local="clr-namespace:SherioAPP.pages"
      mc:Ignorable="d" 
      d:DesignHeight="700" d:DesignWidth="900"
      Title="הפרופיל שלי" FlowDirection="RightToLeft">

    <Grid Background="#F3F4F6">
        <Grid.RowDefinitions>
            <RowDefinition Height="65"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <materialDesign:Card Grid.Row="0" Background="White" UniformCornerRadius="0" Padding="10">
            <Grid>
                <Button HorizontalAlignment="Left" 
                        Style="{StaticResource MaterialDesignFlatButton}" 
                        Click="BackToHome_Click"

                        Foreground="#3B82F6">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Home" Margin="0,0,8,0" VerticalAlignment="Center" Width="22" Height="22"/>
                        <TextBlock Text="חזרה לבית" FontWeight="Bold" VerticalAlignment="Center" FontSize="16"/>
                    </StackPanel>
                </Button>

                <TextBlock Text="SHERIO" FontSize="22" FontWeight="Black" Foreground="#3B82F6" 
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Grid>
        </materialDesign:Card>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden">
            <StackPanel Margin="40" MaxWidth="850">

                <TextBlock Text="הגדרות חשבון" FontSize="28" FontWeight="Bold" Foreground="#1F2937" Margin="0,0,0,25"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.5*"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>

                    <materialDesign:Card Grid.Column="0" Padding="30" UniformCornerRadius="15" Background="White" Margin="0,0,20,0">
                        <StackPanel>
                            <TextBlock Text="עריכת פרטים אישיים" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,25" Foreground="#374151"/>

                            <TextBox x:Name="FullNameBox" 
                                     materialDesign:HintAssist.Hint="שם מלא" 
                                     Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                                     FontSize="16" Margin="0,0,0,20"/>

                            <TextBox x:Name="EmailBox" 
                                     materialDesign:HintAssist.Hint="אימייל (לא ניתן לשינוי)" 
                                     IsReadOnly="True" Foreground="Gray"
                                     Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                                     FontSize="16" Margin="0,0,0,20"/>

                            <TextBox x:Name="PhoneBox" 
                                     materialDesign:HintAssist.Hint="מספר טלפון" 
                                     Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                                     FontSize="16" Margin="0,0,0,35"/>

                            <Button Content="שמור שינויים" 
                                    Click="UpdateProfile_Click"
                                    Height="50" FontSize="16"
                                    materialDesign:ButtonAssist.CornerRadius="10"
                                    Background="#3B82F6" BorderThickness="0" Cursor="Hand"/>
                        </StackPanel>
                    </materialDesign:Card>

                    <StackPanel Grid.Column="1">
                        <materialDesign:Card Padding="20" UniformCornerRadius="15" Background="White" Margin="0,0,0,20">
                            <StackPanel>
                                <TextBlock Text="הפעולות שלי" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,15"/>

                                <Button Style="{StaticResource MaterialDesignFlatButton}" 
                                        Click="MyBookings_Click"
                                        HorizontalContentAlignment="Stretch" Height="55">
                                    <Grid>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                            <materialDesign:PackIcon Kind="CalendarCheck" Margin="0,0,12,0" Width="24" Height="24"/>
                                            <TextBlock Text="ההזמנות שלי" VerticalAlignment="Center" FontSize="15"/>
                                        </StackPanel>
                                        <materialDesign:PackIcon Kind="ChevronLeft" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                    </Grid>
                                </Button>

                                <Separator Background="#F3F4F6" Margin="0,8"/>

                                <Button Style="{StaticResource MaterialDesignFlatButton}" 
                                        Click="Logout_Click"
                                        Foreground="#EF4444"
                                        HorizontalContentAlignment="Left" Height="55">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="Logout" Margin="0,0,12,0" Width="24" Height="24"/>
                                        <TextBlock Text="התנתק מהחשבון" VerticalAlignment="Center" FontSize="15" FontWeight="Medium"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </materialDesign:Card>

                    </StackPanel>
                </Grid>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>