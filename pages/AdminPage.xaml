<Page x:Class="SherioAPP.pages.AdminPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      FlowDirection="RightToLeft"
      Background="#F8FAFC"
      Title="AdminPage"
      Height="500" Width="800">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ===== SIDEBAR ===== -->
        <Border Grid.Column="0" Background="#1E293B">
            <StackPanel>

                <!-- Logo -->
                <TextBlock Text="ADMIN"
                           FontSize="26"
                           FontWeight="ExtraBold"
                           Foreground="White"
                           Margin="20,25,20,30"/>

                <!-- Menu Buttons -->
                <Button Content="משתמשים"
                        Style="{StaticResource MaterialDesignFlatButton}"
                        Foreground="White"
                        HorizontalAlignment="Stretch"
                        Margin="10,5"
                        Click="Button_Click"/>

                <Button Content="מלונות"
                        Style="{StaticResource MaterialDesignFlatButton}"
                        Foreground="White"
                        HorizontalAlignment="Stretch"
                        Margin="10,5"/>

                <Button Content="חדרים"
                        Style="{StaticResource MaterialDesignFlatButton}"
                        Foreground="White"
                        HorizontalAlignment="Stretch"
                        Margin="10,5"/>

                <Button Content="הזמנות"
                        Style="{StaticResource MaterialDesignFlatButton}"
                        Foreground="White"
                        HorizontalAlignment="Stretch"
                        Margin="10,5"/>

                <Button Content="תשלומים"
                        Style="{StaticResource MaterialDesignFlatButton}"
                        Foreground="White"
                        HorizontalAlignment="Stretch"
                        Margin="10,5"/>

                <Separator Margin="10,20"/>

                <Button Content="התנתקות"
                        Style="{StaticResource MaterialDesignFlatButton}"
                        Foreground="#F87171"
                        HorizontalAlignment="Stretch"
                        Margin="10,5"/>
            </StackPanel>
        </Border>

        <!-- ===== MAIN CONTENT ===== -->
        <Grid Grid.Column="1" Margin="25">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,20">
                <TextBlock Text="ניהול מערכת"
                           FontSize="28"
                           FontWeight="ExtraBold"
                           Foreground="#1E293B"/>

                <TextBlock Text=" (Admin)"
                           FontSize="16"
                           Foreground="#64748B"
                           VerticalAlignment="Bottom"
                           Margin="10,0"/>
            </StackPanel>

            <!-- Content Area -->
            <Border Grid.Row="1"
                    Background="White"
                    CornerRadius="16"
                    Padding="20"
                    BorderBrush="#E5E7EB"
                    BorderThickness="1">

                <StackPanel>

                    <TextBlock Text="בחר קטגוריה מהתפריט"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="#334155"
                               Margin="0,0,0,20"/>

                    <!-- Action Buttons -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                        <Button Content="➕ הוספה"
                                Background="#2563EB"
                                Foreground="White"
                                FontWeight="Bold"
                                Width="120"
                                Height="40"
                                Margin="0,0,10,0"
                                materialDesign:ButtonAssist.CornerRadius="10"/>

                        <Button Content="✏️ עריכה"
                                Background="#F59E0B"
                                Foreground="White"
                                FontWeight="Bold"
                                Width="120"
                                Height="40"
                                Margin="0,0,10,0"
                                materialDesign:ButtonAssist.CornerRadius="10"/>

                        <Button Content="🗑 מחיקה"
                                Background="#EF4444"
                                Foreground="White"
                                FontWeight="Bold"
                                Width="120"
                                Height="40"
                                materialDesign:ButtonAssist.CornerRadius="10"/>
                    </StackPanel>

                    <!-- Placeholder Table -->
                    <Border Background="#F1F5F9"
        CornerRadius="12"
        Height="220"
        Padding="15">
                        <TextBlock Text="כאן תופיע רשימה (DataGrid) של הנתונים"
               Foreground="#64748B"
               FontSize="14"
               VerticalAlignment="Center"
               HorizontalAlignment="Center"/>
                    </Border>

                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Page>
