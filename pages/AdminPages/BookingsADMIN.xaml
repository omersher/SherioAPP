<Page x:Class="SherioAPP.pages.AdminPages.BookingsADMIN"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      FlowDirection="RightToLeft" 
      Background="#F8FAFC" 
      Height="500" Width="800">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="ניהול הזמנות" FontSize="24" FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,12"/>
        <Button Content="⬅ חזרה לפאנל"
        Width="150"
        Height="35"
        HorizontalAlignment="Right"
        Margin="0,0,0,10"
        Click="BackToAdmin_Click"/>
        <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="10,2" Margin="0,0,0,15" BorderBrush="#E2E8F0" BorderThickness="1">
            <DockPanel>
                <materialDesign:PackIcon Kind="Magnify" Foreground="#94A3B8" VerticalAlignment="Center" Margin="5,0"/>
                <TextBox x:Name="SearchBox" FontSize="13" BorderThickness="0" VerticalContentAlignment="Center"
                         TextChanged="SearchBox_TextChanged"
                         materialDesign:HintAssist.Hint="חפש לפי שם לקוח או סטטוס..."
                         materialDesign:TextFieldAssist.DecorationVisibility="Collapsed"/>
            </DockPanel>
        </Border>

        <Border Grid.Row="2" Background="White" CornerRadius="10" ClipToBounds="True" BorderBrush="#E2E8F0" BorderThickness="1">
            <DataGrid x:Name="BookingsGrid" AutoGenerateColumns="False" IsReadOnly="True" 
                      RowHeight="55" Background="White" BorderThickness="0"
                      GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#F1F5F9"
                      materialDesign:DataGridAssist.CellPadding="10">

                <DataGrid.Resources>
                    <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource MaterialDesignDataGridColumnHeader}">
                        <Setter Property="Background" Value="#F8FAFC"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                    </Style>
                </DataGrid.Resources>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="לקוח" Binding="{Binding UserID}" Width="1.5*"/>

                    <DataGridTemplateColumn Header="תאריך" Width="1.2*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Calendar" Width="14" Foreground="#64748B" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Date, StringFormat={}{0:dd/MM/yyyy}}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="סטטוס" Width="1*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Padding="8,4" CornerRadius="12" HorizontalAlignment="Right" Background="#F1F5F9">
                                    <TextBlock Text="{Binding Status}" FontSize="11" FontWeight="Medium" Foreground="#475569"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="פעולות" Width="100">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button Style="{StaticResource MaterialDesignIconButton}" 
                                            Click="ApproveBooking_Click"
                                            Width="32" Height="32" Foreground="#10B981" ToolTip="אשר הזמנה">
                                        <materialDesign:PackIcon Kind="CheckCircleOutline" Width="20" Height="20"/>
                                    </Button>

                                    <Button Style="{StaticResource MaterialDesignIconButton}" 
                                            Click="CancelBooking_Click"
                                            Width="32" Height="32" Foreground="#EF4444" ToolTip="בטל הזמנה" Margin="4,0,0,0">
                                        <materialDesign:PackIcon Kind="CloseCircleOutline" Width="20" Height="20"/>
                                    </Button>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Page>