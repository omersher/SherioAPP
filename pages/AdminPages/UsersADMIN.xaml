<Page x:Class="SherioAPP.pages.AdminPages.UsersADMIN"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      FlowDirection="RightToLeft"
      Background="#F8FAFC"
      Title="UsersADMIN"
      Height="500"
      Width="800">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- כותרת -->
        <TextBlock Text="ניהול משתמשים"
                   FontSize="26"
                   FontWeight="ExtraBold"
                   Foreground="#1E293B"
                   Margin="0,0,0,15"/>

        <!-- חיפוש -->
        <Border Grid.Row="1"
                Background="White"
                CornerRadius="12"
                Padding="12"
                Margin="0,0,0,15"
                BorderBrush="#E5E7EB"
                BorderThickness="1">
            <DockPanel>
                <materialDesign:PackIcon Kind="AccountSearch"
                                         Width="22"
                                         Height="22"
                                         Foreground="#2563EB"
                                         Margin="0,0,10,0"/>

                <TextBox x:Name="SearchBox"
                         FontSize="14"
                         VerticalContentAlignment="Center"
                         Background="Transparent"
                         BorderThickness="0"
                         TextChanged="SearchBox_TextChanged"
                         />
            </DockPanel>
        </Border>

        <!-- טבלת משתמשים -->
        <DataGrid Grid.Row="2"
                  x:Name="UsersGrid"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  IsReadOnly="True"
                  RowHeight="45"
                  HeadersVisibility="Column"
                  Background="White"
                  BorderThickness="0"
                  GridLinesVisibility="None">

            <DataGrid.Columns>

                <DataGridTextColumn Header="שם מלא"
                                    Binding="{Binding FullName}"
                                    Width="2*"/>

                <DataGridTextColumn Header="אימייל"
                                    Binding="{Binding Email}"
                                    Width="2*"/>

                <DataGridTextColumn Header="טלפון"
                                    Binding="{Binding Phone}"
                                    Width="1.5*"/>

                <DataGridTemplateColumn Header="פעולות" Width="2*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">

                                <Button Content="חסום"
                                        Background="#F59E0B"
                                        Foreground="White"
                                        FontSize="12"
                                        Padding="10,4"
                                        Margin="3"
                                        materialDesign:ButtonAssist.CornerRadius="8"/>

                                <Button Content="מחק"
                                        Background="#EF4444"
                                        Foreground="White"
                                        FontSize="12"
                                        Padding="10,4"
                                        Margin="3"
                                        materialDesign:ButtonAssist.CornerRadius="8"/>

                                <Button Content="Admin"
                                        Background="#2563EB"
                                        Foreground="White"
                                        FontSize="12"
                                        Padding="10,4"
                                        Margin="3"
                                        materialDesign:ButtonAssist.CornerRadius="8"/>

                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>