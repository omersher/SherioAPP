<Page x:Class="SherioAPP.pages.AdminPages.RoomsADMIN"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      FlowDirection="RightToLeft" Background="#F8FAFC" Height="500" Width="800">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="ניהול חדרים" FontSize="26" FontWeight="ExtraBold" Foreground="#1E293B" Margin="0,0,0,15"/>

        <Border Grid.Row="1" Background="White" CornerRadius="12" Padding="12" Margin="0,0,0,15" BorderBrush="#E5E7EB" BorderThickness="1">
            <DockPanel>
                <materialDesign:PackIcon Kind="Bed" Width="22" Height="22" Foreground="#2563EB" Margin="0,0,10,0"/>
                <TextBox x:Name="SearchBox" FontSize="14" VerticalContentAlignment="Center" Background="Transparent" BorderThickness="0" Tag="חפש חדר לפי סוג או מלון..."/>
            </DockPanel>
        </Border>
        <Button Content="⬅ חזרה לפאנל"
        Width="150"
        Height="35"
        HorizontalAlignment="Right"
        Margin="0,0,0,10"
        Click="BackToAdmin_Click"/>

        <DataGrid Grid.Row="2" x:Name="RoomsGrid" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" RowHeight="45" Background="White" BorderThickness="0">
            <DataGrid.Columns>
                <DataGridTextColumn Header="מלון" Binding="{Binding HotelName}" Width="1.5*"/>
                <DataGridTextColumn Header="סוג חדר" Binding="{Binding Type}" Width="1.5*"/>
                <DataGridTextColumn Header="מחיר ללילה" Binding="{Binding PricePerNight}" Width="1*"/>
                <DataGridTemplateColumn Header="פעולות" Width="1.5*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="ערוך" Background="#2563EB" Foreground="White" Margin="3" materialDesign:ButtonAssist.CornerRadius="6"/>
                                <Button Content="מחק" Background="#EF4444" Foreground="White" Margin="3" materialDesign:ButtonAssist.CornerRadius="6"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>