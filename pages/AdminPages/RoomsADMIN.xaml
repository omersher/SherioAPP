<Page x:Class="SherioAPP.pages.AdminPages.RoomsADMIN"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      FlowDirection="RightToLeft"
      Background="#F8FAFC"
      Height="500" Width="800">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="ניהול חדרים"
                       FontSize="22"
                       FontWeight="ExtraBold"
                       Foreground="#1E293B"/>
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="White"
                    CornerRadius="8"
                    Padding="8"
                    Margin="0,0,10,0"
                    BorderBrush="#E5E7EB"
                    BorderThickness="1">
                <DockPanel>
                    <materialDesign:PackIcon Kind="Magnify"
                                             Foreground="#2563EB"
                                             Margin="0,0,5,0"
                                             VerticalAlignment="Center"/>
                    <TextBox x:Name="SearchBox"
                             FontSize="13"
                             BorderThickness="0"
                             TextChanged="SearchBox_TextChanged"
                             materialDesign:HintAssist.Hint="חיפוש לפי שם חדר / מזהה חדר / מזהה מלון..." />
                </DockPanel>
            </Border>

            <Button Grid.Column="1"
                    Content="💾 שמור"
                    Background="#10B981"
                    BorderBrush="#10B981"
                    Foreground="White"
                    Height="35"
                    Margin="0,0,5,0"
                    Click="SaveChanges_Click"/>

            <Button Grid.Column="2"
                    Content="⬅ חזרה"
                    Width="100"
                    Height="35"
                    Click="BackToAdmin_Click"/>
        </Grid>

        <Border Grid.Row="2"
                Background="White"
                CornerRadius="8"
                BorderBrush="#E5E7EB"
                BorderThickness="1">

            <DataGrid x:Name="RoomsGrid"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      IsReadOnly="False"
                      RowHeight="40"
                      Background="White"
                      BorderThickness="0"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="#F1F5F9"
                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                      ScrollViewer.VerticalScrollBarVisibility="Auto">

                <DataGrid.Columns>
                    <DataGridTextColumn Header="מזהה"
                                        Binding="{Binding Id}"
                                        IsReadOnly="True"
                                        Width="55"/>

                    <DataGridTextColumn Header="מלון ID"
                                        Binding="{Binding Hotel.Id}"
                                        IsReadOnly="True"
                                        Width="70"/>

                    <DataGridTextColumn Header="שם חדר"
                                        Binding="{Binding RoomName}"
                                        Width="140"/>

                    <DataGridTextColumn Header="מחיר מבוגר"
                                        Binding="{Binding AdultRate}"
                                        Width="90"/>

                    <DataGridTextColumn Header="מחיר ילד"
                                        Binding="{Binding ChildRate}"
                                        Width="90"/>

                    <DataGridTextColumn Header="שינה"
                                        Binding="{Binding Bedrooms}"
                                        Width="60"/>

                    <DataGridTextColumn Header="מקלחות"
                                        Binding="{Binding Bathrooms}"
                                        Width="70"/>

                    <DataGridTextColumn Header="יחידות"
                                        Binding="{Binding TotalUnits}"
                                        Width="65"/>

                    <DataGridCheckBoxColumn Header="מטבח"
                                            Binding="{Binding HasKitchen}"
                                            Width="60"/>

                    <DataGridCheckBoxColumn Header="חניה"
                                            Binding="{Binding HasParking}"
                                            Width="60"/>

                    <DataGridCheckBoxColumn Header="מרפסת"
                                            Binding="{Binding HasBalcony}"
                                            Width="65"/>

                    <DataGridCheckBoxColumn Header="סלון"
                                            Binding="{Binding HasLivingRoom}"
                                            Width="60"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Page>