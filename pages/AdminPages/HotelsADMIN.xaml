<Page x:Class="SherioAPP.pages.AdminPages.HotelsADMIN"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      FlowDirection="RightToLeft"
      Background="#F1F5F9"
      Height="500" Width="800">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="ניהול מלונות"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="#0F172A"/>
            <TextBlock Text="ערוך, מחק או נהל את רשימת המלונות במערכת"
                       FontSize="14"
                       Foreground="#64748B"
                       Margin="0,4,0,0"/>
        </StackPanel>

        <Border Grid.Row="1" Background="White" CornerRadius="10" Padding="8,4" Margin="0,0,0,20" 
                BorderBrush="#E2E8F0" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <materialDesign:PackIcon Kind="Magnify" Width="20" Height="20" Foreground="#94A3B8" 
                                         VerticalAlignment="Center" Margin="10,0"/>
                <TextBox Grid.Column="1" x:Name="SearchBox" FontSize="14" BorderThickness="0"
                         VerticalContentAlignment="Center" Background="Transparent"
                         TextChanged="SearchBox_TextChanged" 
                         materialDesign:HintAssist.Hint="חפש לפי שם מלון או כתובת..."
                         materialDesign:TextFieldAssist.DecorationVisibility="Collapsed"/>
            </Grid>
        </Border>

        <Border Grid.Row="2" Background="White" CornerRadius="12" ClipToBounds="True" BorderBrush="#E2E8F0" BorderThickness="1">
            <DataGrid x:Name="HotelsGrid" AutoGenerateColumns="False" CanUserAddRows="False" 
                      IsReadOnly="False" RowHeight="60" Background="White" 
                      BorderThickness="0" HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#F1F5F9"
                      materialDesign:DataGridAssist.CellPadding="12">

                <DataGrid.Resources>
                    <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource MaterialDesignDataGridColumnHeader}">
                        <Setter Property="Background" Value="#F8FAFC"/>
                        <Setter Property="Padding" Value="12,15"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Foreground" Value="#475569"/>
                    </Style>
                </DataGrid.Resources>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="שם המלון" Binding="{Binding Name}" Width="1.5*" FontWeight="Medium"/>
                    <DataGridTextColumn Header="עיר" Binding="{Binding City.CityName}" IsReadOnly="True" Width="*"/>
                    <DataGridTextColumn Header="כתובת" Binding="{Binding StreetAddress}" Width="1.5*"/>

                    <DataGridTemplateColumn Header="דירוג" Width="80">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding StarRating}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                    <materialDesign:PackIcon Kind="Star" Foreground="#F59E0B" Width="14" VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridCheckBoxColumn Header="בריכה" Binding="{Binding HasPool}" Width="70"/>
                    <DataGridCheckBoxColumn Header="כושר" Binding="{Binding HasGym}" Width="70"/>

                    <DataGridTemplateColumn Header="פעולות" Width="120">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button Style="{StaticResource MaterialDesignIconButton}"
                                            Click="SaveSingleHotel_Click" Width="35" Height="35"
                                            ToolTip="שמור שינויים" Foreground="#10B981">
                                        <materialDesign:PackIcon Kind="ContentSaveOutline" Width="20" Height="20"/>
                                    </Button>

                                    <Button Style="{StaticResource MaterialDesignIconButton}"
                                            Click="DeleteHotel_Click" Width="35" Height="35"
                                            ToolTip="מחק מלון" Foreground="#EF4444" Margin="5,0,0,0">
                                        <materialDesign:PackIcon Kind="DeleteOutline" Width="20" Height="20"/>
                                    </Button>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Page>