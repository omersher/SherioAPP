<Page x:Class="SherioAPP.pages.AdminPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      FlowDirection="RightToLeft"
      Background="#F1F5F9" 
      Height="500" Width="800">

    <Grid>
        <StackPanel Margin="40" VerticalAlignment="Center">

            <TextBlock Text="פאנל ניהול מערכת" 
                       FontSize="36" FontWeight="Black" 
                       Foreground="#1E293B" HorizontalAlignment="Center" Margin="0,0,0,10"/>
            <TextBlock Text="שלום אדמין, בחר פעולה לביצוע" 
                       FontSize="16" Foreground="#64748B" HorizontalAlignment="Center" Margin="0,0,0,40"/>

            <UniformGrid Columns="3">

                <Button Style="{StaticResource MaterialDesignFlatButton}" Click="Users_Click" Height="130" Margin="10">
                    <materialDesign:Card UniformCornerRadius="15" Background="White" Padding="20">
                        <StackPanel VerticalAlignment="Center">
                            <materialDesign:PackIcon Kind="AccountGroup" HorizontalAlignment="Center" Width="35" Height="35" Foreground="#2563EB"/>
                            <TextBlock Text="משתמשים" Margin="0,10,0,0" FontSize="16" FontWeight="Bold" Foreground="#1E293B" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </materialDesign:Card>
                </Button>

                <Button Style="{StaticResource MaterialDesignFlatButton}" Click="Hotels_Click" Height="130" Margin="10">
                    <materialDesign:Card UniformCornerRadius="15" Background="White" Padding="20">
                        <StackPanel VerticalAlignment="Center">
                            <materialDesign:PackIcon Kind="Hotel" HorizontalAlignment="Center" Width="35" Height="35" Foreground="#2563EB"/>
                            <TextBlock Text="מלונות" Margin="0,10,0,0" FontSize="16" FontWeight="Bold" Foreground="#1E293B" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </materialDesign:Card>
                </Button>

                <Button Style="{StaticResource MaterialDesignFlatButton}" Click="Rooms_Click" Height="130" Margin="10">
                    <materialDesign:Card UniformCornerRadius="15" Background="White" Padding="20">
                        <StackPanel VerticalAlignment="Center">
                            <materialDesign:PackIcon Kind="Bed" HorizontalAlignment="Center" Width="35" Height="35" Foreground="#2563EB"/>
                            <TextBlock Text="חדרים" Margin="0,10,0,0" FontSize="16" FontWeight="Bold" Foreground="#1E293B" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </materialDesign:Card>
                </Button>

                <Button Style="{StaticResource MaterialDesignFlatButton}" Click="Bookings_Click" Height="130" Margin="10">
                    <materialDesign:Card UniformCornerRadius="15" Background="White" Padding="20">
                        <StackPanel VerticalAlignment="Center">
                            <materialDesign:PackIcon Kind="CalendarCheck" HorizontalAlignment="Center" Width="35" Height="35" Foreground="#2563EB"/>
                            <TextBlock Text="הזמנות" Margin="0,10,0,0" FontSize="16" FontWeight="Bold" Foreground="#1E293B" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </materialDesign:Card>
                </Button>

                <Button Style="{StaticResource MaterialDesignFlatButton}" Click="Payments_Click" Height="130" Margin="10">
                    <materialDesign:Card UniformCornerRadius="15" Background="White" Padding="20">
                        <StackPanel VerticalAlignment="Center">
                            <materialDesign:PackIcon Kind="CreditCard" HorizontalAlignment="Center" Width="35" Height="35" Foreground="#2563EB"/>
                            <TextBlock Text="תשלומים" Margin="0,10,0,0" FontSize="16" FontWeight="Bold" Foreground="#1E293B" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </materialDesign:Card>
                </Button>

                <Button Style="{StaticResource MaterialDesignFlatButton}" Click="Logout_Click" Height="130" Margin="10">
                    <materialDesign:Card UniformCornerRadius="15" Background="White" Padding="20">
                        <StackPanel VerticalAlignment="Center">
                            <materialDesign:PackIcon Kind="Logout" HorizontalAlignment="Center" Width="35" Height="35" Foreground="#DC2626"/>
                            <TextBlock Text="התנתקות" Margin="0,10,0,0" FontSize="16" FontWeight="Bold" Foreground="#DC2626" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </materialDesign:Card>
                </Button>

            </UniformGrid>
        </StackPanel>

        <Frame x:Name="AdminFrame" NavigationUIVisibility="Hidden"/>
    </Grid>
</Page>