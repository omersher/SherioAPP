<Page x:Class="SherioAPP.pages.OwnerPages.RoomsManagementPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      Width="800" Height="500"
      FlowDirection="RightToLeft"
      Background="#F1F5F9">

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="ניהול מלאי חדרים"
                       FontSize="30"
                       FontWeight="ExtraBold"
                       Foreground="#1E293B"/>
            <TextBlock Text="כאן ניתן לערוך מחירים ושירותים לכל סוג חדר"
                       FontSize="14"
                       Foreground="#64748B"
                       Margin="2,5,0,0"/>
        </StackPanel>

        <materialDesign:Card Grid.Row="1"
                             UniformCornerRadius="15"
                             materialDesign:ElevationAssist.Elevation="Dp2"
                             Background="White">

            <DataGrid x:Name="RoomsGrid"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      SelectionMode="Single"
                      RowHeight="55"
                      FontSize="14"
                      Background="Transparent"
                      BorderThickness="0">

                <DataGrid.Columns>
                    <DataGridTextColumn Header="שם החדר"
                                        Binding="{Binding RoomName, UpdateSourceTrigger=PropertyChanged}"
                                        Width="*"/>

                    <DataGridTextColumn Header="מחיר מבוגר"
                                        Binding="{Binding AdultRate, UpdateSourceTrigger=PropertyChanged}"
                                        Width="*"/>

                    <DataGridTextColumn Header="מחיר ילד"
                                        Binding="{Binding ChildRate, UpdateSourceTrigger=PropertyChanged}"
                                        Width="*"/>

                    <DataGridTextColumn Header="שינה"
                                        Binding="{Binding Bedrooms, UpdateSourceTrigger=PropertyChanged}"
                                        Width="80"/>

                    <DataGridTextColumn Header="אמבט"
                                        Binding="{Binding Bathrooms, UpdateSourceTrigger=PropertyChanged}"
                                        Width="80"/>

                    <DataGridCheckBoxColumn Header="מטבח"
                                            Binding="{Binding HasKitchen, UpdateSourceTrigger=PropertyChanged}"
                                            Width="80"/>

                    <DataGridCheckBoxColumn Header="חניה"
                                            Binding="{Binding HasParking, UpdateSourceTrigger=PropertyChanged}"
                                            Width="80"/>
                </DataGrid.Columns>
            </DataGrid>
        </materialDesign:Card>

        <Button Grid.Row="2"
                Content="שמור שינויים"
                Width="200"
                Height="45"
                Margin="0,20,0,0"
                Background="#2563EB"
                Foreground="White"
                FontSize="16"
                Click="Save_Click"/>
    </Grid>
</Page>
