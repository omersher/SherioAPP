<Page x:Class="SherioAPP.pages.OwnerPages.RoomsManagementPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      Width="800"
      Height="500"
      FlowDirection="RightToLeft"
      Background="#F1F5F9">

    <materialDesign:DialogHost x:Name="ImagesDialogHost">

        <materialDesign:DialogHost.DialogContent>

            <Border Background="White"
                    Padding="20"
                    Width="600"
                    CornerRadius="12">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <DataGrid x:Name="PopupImagesGrid"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False">

                        <DataGrid.Columns>

                            <DataGridTextColumn Header="קישור לתמונה"
                                                Binding="{Binding ImageUrl}"
                                                Width="*"/>

                            <DataGridTemplateColumn Header="מחיקה" Width="80">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="🗑"
                                                Tag="{Binding Id}"
                                                Click="DeletePopupImage_Click"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Grid.Row="1"
                                Orientation="Horizontal"
                                Margin="0,15,0,0">

                        <TextBox x:Name="PopupUrlBox"
                                 Width="350"
                                 Margin="0,0,10,0"/>

                        <Button Content="הוסף"
                                Width="80"
                                Click="AddPopupImage_Click"/>

                        <Button Content="סגור"
                                Width="80"
                                Margin="10,0,0,0"
                                Click="CloseDialog_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

        </materialDesign:DialogHost.DialogContent>

        <!-- התוכן הרגיל שלך -->
        <Grid Margin="25">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,20">
                <TextBlock Text="ניהול מלאי חדרים"
                           FontSize="30"
                           FontWeight="ExtraBold"
                           Foreground="#1E293B"/>
                <TextBlock Text="כאן ניתן לערוך מחירים ושירותים לכל סוג חדר"
                           FontSize="14"
                           Foreground="#64748B"
                           Margin="2,5,0,0"/>
            </StackPanel>

            <materialDesign:Card Grid.Row="1"
                                 UniformCornerRadius="15"
                                 Background="White">

                <DataGrid x:Name="RoomsGrid"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          RowHeight="55">

                    <DataGrid.Columns>

                        <DataGridTextColumn Header="שם החדר"
                                            Binding="{Binding RoomName}"
                                            Width="*"/>

                        <DataGridTextColumn Header="מחיר מבוגר"
                                            Binding="{Binding AdultRate}"
                                            Width="*"/>

                        <DataGridTemplateColumn Header="תמונות" Width="90">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="📷"
                                            Width="40"
                                            Click="OpenImages_Click"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                    </DataGrid.Columns>

                </DataGrid>
            </materialDesign:Card>

            <Button Grid.Row="2"
                    Content="שמור שינויים"
                    Width="200"
                    Height="45"
                    Margin="0,20,0,0"
                    Background="#2563EB"
                    Foreground="White"
                    Click="Save_Click"/>
        </Grid>

    </materialDesign:DialogHost>
</Page>