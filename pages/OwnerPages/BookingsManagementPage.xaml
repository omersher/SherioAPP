<Page x:Class="SherioAPP.pages.OwnerPages.BookingsManagementPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Height="500" Width="800" FlowDirection="RightToLeft" Background="#F8FAFC">
    <Grid Margin="20">
        <TextBlock Text="יומן הזמנות" FontSize="24" FontWeight="Bold" Margin="0,0,0,20"/>
        <DataGrid Margin="0,50,0,0" Background="White" AutoGenerateColumns="False" CanUserAddRows="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="שם לקוח" Binding="{Binding Customer}" Width="*"/>
                <DataGridTextColumn Header="חדר" Binding="{Binding RoomNum}" Width="80"/>
                <DataGridTextColumn Header="כניסה" Binding="{Binding CheckIn}" Width="120"/>
                <DataGridTextColumn Header="יציאה" Binding="{Binding CheckOut}" Width="120"/>
                <DataGridTextColumn Header="סטטוס" Binding="{Binding Status}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>