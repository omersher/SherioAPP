<Page x:Class="SherioAPP.pages.OwnerPages.BookingsManagementPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      xmlns:sys="clr-namespace:System;assembly=mscorlib"
      Height="500" Width="800"
      FlowDirection="RightToLeft"
      Background="#F8FAFC">

    <Page.Resources>
        <x:Array x:Key="StatusOptions" Type="sys:String">
            <sys:String>Pending</sys:String>
            <sys:String>Confirmed</sys:String>
            <sys:String>Cancelled</sys:String>
            <sys:String>CheckedIn</sys:String>
            <sys:String>CheckedOut</sys:String>
        </x:Array>
    </Page.Resources>

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Margin="0,0,0,20">
            <TextBlock Text="יומן הזמנות" FontSize="28" FontWeight="ExtraBold" Foreground="#1E293B"/>
            <TextBlock Text="נהל סטטוסים וכמויות אורחים עבור כל הזמנה" FontSize="14" Foreground="#64748B"/>
        </StackPanel>

        <materialDesign:Card Grid.Row="1" materialDesign:ElevationAssist.Elevation="Dp2" UniformCornerRadius="8">
            <DataGrid x:Name="BookingsGrid"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      IsReadOnly="False"
                      SelectionMode="Single"
                      Background="White"
                      BorderThickness="0"
                      GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="#F1F5F9"
                      RowHeight="50">

                <DataGrid.Columns>
                    <DataGridTextColumn Header="חדר" 
                                        Binding="{Binding RoomID}" 
                                        IsReadOnly="True"
                                        Width="Auto"/>

                    <DataGridTextColumn Header="כניסה" 
                                        Binding="{Binding StartDate, StringFormat=\{0:dd/MM/yyyy\}}" 
                                        IsReadOnly="True"
                                        Width="*"/>

                    <DataGridTextColumn Header="יציאה" 
                                        Binding="{Binding EndDate, StringFormat=\{0:dd/MM/yyyy\}}" 
                                        IsReadOnly="True"
                                        Width="*"/>

                    <DataGridTextColumn Header="מבוגרים" 
                                        Binding="{Binding AdultCount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        Width="80"/>

                    <DataGridTextColumn Header="ילדים" 
                                        Binding="{Binding ChildCount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        Width="80"/>

                    <DataGridTemplateColumn Header="סטטוס" Width="150">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Padding="8,4" 
                    CornerRadius="4" 
                    Background="#F1F5F9" 
                    HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding Status}" 
                           FontWeight="SemiBold" 
                           Foreground="#1E293B"
                           VerticalAlignment="Center"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>

                        <DataGridTemplateColumn.CellEditingTemplate>
                            <DataTemplate>
                                <ComboBox SelectedValue="{Binding Status, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                      ItemsSource="{StaticResource StatusOptions}"
                      IsDropDownOpen="True"
                      Style="{StaticResource MaterialDesignComboBox}">
                                </ComboBox>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellEditingTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </materialDesign:Card>

        <Button Grid.Row="2"
                Content="שמור שינויים במערכת"
                Style="{StaticResource MaterialDesignRaisedButton}"
                materialDesign:ButtonAssist.CornerRadius="8"
                Width="200" Height="45"
                Margin="0,20,0,0"
                HorizontalAlignment="Left"
                Background="#2563EB"
                Click="SaveChanges_Click"/>
    </Grid>
</Page>