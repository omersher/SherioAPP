<Page x:Class="SherioAPP.pages.OwnerPages.HotelDetailsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      Width="800" Height="500" FlowDirection="RightToLeft" Background="#F8FAFC">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="ניהול פרטי מלון ומדיה" FontSize="22" FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,12"/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.8*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Margin="0,0,15,0">
                <Grid Height="260">
                    <Border CornerRadius="20" ClipToBounds="True">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="1*"/>
                            </Grid.ColumnDefinitions>

                            <Image Grid.Column="0" Source="{Binding MainImageLink}" 
                                   Stretch="UniformToFill" Margin="0,0,4,0"/>

                            <Grid Grid.Column="1">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Image Grid.Row="0" Source="{Binding SideImage1}" Stretch="UniformToFill" Margin="0,0,0,2"/>
                                <Image Grid.Row="1" Source="{Binding SideImage2}" Stretch="UniformToFill" Margin="0,2,0,0"/>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </StackPanel>

            <Border Grid.Column="1" Background="White" CornerRadius="16" Padding="16" BorderBrush="#E2E8F0" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="ערוך פרטים" FontSize="16" FontWeight="Bold" Margin="0,0,0,12"/>

                    <TextBlock Text="שם המלון" FontSize="12" Foreground="#64748B"/>
                    <TextBox Text="{Binding HotelName, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,15" 
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"/>

                    <TextBlock Text="לינק תמונה ראשית" FontSize="12" Foreground="#64748B"/>
                    <TextBox Text="{Binding MainImageLink, UpdateSourceTrigger=PropertyChanged}" 
                             Margin="0,4,0,15" Style="{StaticResource MaterialDesignOutlinedTextBox}"/>

                    <Button Content="שמור שינויים במערכת" Click="SaveDetails_Click"
                            Height="45" Background="#2563EB" materialDesign:ButtonAssist.CornerRadius="10"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Page>