<Page x:Class="SherioAPP.pages.OwnerPages.HotelDetailsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      Width="800" Height="500"
      FlowDirection="RightToLeft"
      Background="#F8FAFC">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Margin="10,0,0,15">
            <TextBlock x:Name="HeaderName"
                       Text="שם המלון"
                       FontSize="26"
                       FontWeight="Black"
                       Foreground="#1E293B"/>
            <TextBlock Text="ניהול פרטי מלון"
                       FontSize="13"
                       Foreground="#64748B"/>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.2*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <materialDesign:Card Grid.Column="0"
                                 Margin="0,0,10,5"
                                 UniformCornerRadius="16">
                <Grid>
                    <Image x:Name="PreviewImage"
                           Stretch="UniformToFill"/>

                    <Border VerticalAlignment="Bottom"
                            Height="50"
                            Background="#CC000000">
                        <TextBlock x:Name="ImageOverlayName"
                                   Foreground="White"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Margin="15,0"
                                   VerticalAlignment="Center"/>
                    </Border>
                </Grid>
            </materialDesign:Card>

            <materialDesign:Card Grid.Column="1"
                                 Padding="15"
                                 UniformCornerRadius="12"
                                 Background="White">

                <ScrollViewer VerticalScrollBarVisibility="Hidden">
                    <StackPanel>

                        <TextBox x:Name="NameBox"
                                 materialDesign:HintAssist.Hint="שם המלון"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Margin="0,0,0,10"
                                 TextChanged="NameBox_TextChanged"/>

                        <TextBox x:Name="PhoneBox"
                                 materialDesign:HintAssist.Hint="טלפון"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Margin="0,0,0,10"/>

                        <TextBox x:Name="EmailBox"
                                 materialDesign:HintAssist.Hint="אימייל"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Margin="0,0,0,10"/>

                        <TextBox x:Name="WebsiteBox"
                                 materialDesign:HintAssist.Hint="אתר"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Margin="0,0,0,10"/>

                        <TextBox x:Name="AddressBox"
                                 materialDesign:HintAssist.Hint="כתובת"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Margin="0,0,0,10"/>

                        <TextBlock Text="תמונה ראשית של המלון"
                                   Margin="0,5,0,12"
                                   FontWeight="Bold"
                                   Foreground="#64748B"/>

                        <StackPanel Orientation="Horizontal"
                                    Margin="0,0,0,20">
                            <CheckBox x:Name="PoolCheck"
                                      Content="בריכה"
                                      Margin="0,0,15,0"/>
                            <CheckBox x:Name="GymCheck"
                                      Content="חדר כושר"
                                      Margin="0,0,15,0"/>
                            <CheckBox x:Name="RestaurantCheck"
                                      Content="מסעדה"/>
                        </StackPanel>

                        <Button Content="שמור שינויים"
                                Click="Save_Click"
                                Height="40"
                                Background="#2563EB"
                                Foreground="White"
                                materialDesign:ButtonAssist.CornerRadius="8"/>
                    </StackPanel>
                </ScrollViewer>
            </materialDesign:Card>
        </Grid>
    </Grid>
</Page>