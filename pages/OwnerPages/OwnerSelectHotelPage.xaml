<Page x:Class="SherioAPP.pages.OwnerPages.OwnerSelectHotelPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      Width="800" Height="500"
      FlowDirection="RightToLeft"
      Background="#F8FAFC">

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Margin="0,0,0,25">
            <TextBlock Text="ניהול המלונות שלי" FontSize="28" FontWeight="ExtraBold" Foreground="#1E293B"/>
            <TextBlock Text="בחר מלון מהרשימה כדי לעבור למסך הניהול" FontSize="14" Foreground="#64748B" Margin="2,5,0,0"/>
        </StackPanel>

        <ListBox x:Name="HotelsListBox"
                 Grid.Row="1"
                 ScrollViewer.VerticalScrollBarVisibility="Disabled"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 HorizontalContentAlignment="Stretch"
                 BorderThickness="0"
                 Background="Transparent">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Background="White"
                            CornerRadius="10"
                            Padding="15"
                            Margin="0,5"
                            BorderBrush="#E2E8F0"
                            BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <!-- כותרת -->
                                <TextBlock Text="{Binding Name}"
                                           FontSize="18"
                                           FontWeight="Bold"
                                           Foreground="#1E293B"/>

                                <!-- עיר -->
                                <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                    <materialDesign:PackIcon Kind="MapMarker" Foreground="#2563EB" Width="15"/>
                                    <TextBlock Text="{Binding City.CityName}"
                                               FontSize="14"
                                               Foreground="#64748B"
                                               Margin="5,0,0,0"/>
                                </StackPanel>
                            </StackPanel>

                            <materialDesign:PackIcon Grid.Column="1"
                                                     Kind="ChevronLeft"
                                                     VerticalAlignment="Center"
                                                     Foreground="#CBD5E1"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <Button Grid.Row="2"
                Content="המשך לניהול מלון נבחר"
                Height="50" Width="220"
                HorizontalAlignment="Left"
                Margin="0,20,0,0"
                BorderThickness="0"
                Background="#2563EB"
                Foreground="White"
                FontSize="16"
                FontWeight="Bold"
                materialDesign:ButtonAssist.CornerRadius="12"
                Click="SelectHotel_Click">
            <Button.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.2"/>
            </Button.Effect>
        </Button>
    </Grid>
</Page>
