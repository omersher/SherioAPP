<Page x:Class="SherioAPP.pages.OwnerPages.OwnerPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Width="800" Height="500"
      FlowDirection="RightToLeft"
      Background="#F8FAFC">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Margin="0,0,0,20">
            <TextBlock Text="לוח בקרה למנהל"
                       FontSize="28"
                       FontWeight="Bold"/>
            <TextBlock Text="{Binding Name}"
                       FontSize="14"
                       Foreground="Gray"/>
        </StackPanel>

        <UniformGrid Grid.Row="1" Columns="3">
            <Button Content="ניהול חדרים" Click="Rooms_Click"/>
            <Button Content="הזמנות" Click="Bookings_Click"/>
            <Button Content="פרטי המלון" Click="HotelDetails_Click"/>
        </UniformGrid>
    </Grid>
</Page>
